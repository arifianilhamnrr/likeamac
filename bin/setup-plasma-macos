#!/usr/bin/env bash
set -euo pipefail

export QT_QPA_PLATFORMTHEME=kvantum

# Themes
plasma-apply-colorscheme WhiteSurDark 2>/dev/null || plasma-apply-colorscheme WhiteSurDark 2>/dev/null || true
plasma-apply-desktoptheme NoctaliaBar 2>/dev/null || plasma-apply-desktoptheme WhiteSur-dark 2>/dev/null || true
plasma-apply-wallpaperimage "$HOME/Pictures/Wallpapers/japan-artistic-5120x2880-25406.jpg" 2>/dev/null || true
plasma-apply-cursortheme WhiteSur-cursors 2>/dev/null || true

kwriteconfig6 --file kdeglobals --group General --key ColorScheme WhiteSurDark
kwriteconfig6 --file kdeglobals --group Icons --key Theme WhiteSur-dark
kwriteconfig6 --file kdeglobals --group KDE --key widgetStyle kvantum-dark
kwriteconfig6 --file plasmarc --group Theme --key name WhiteSur-dark
kwriteconfig6 --file kwinrc --group org.kde.kdecoration2 --key library org.kde.kwin.aurorae
kwriteconfig6 --file kwinrc --group org.kde.kdecoration2 --key theme __aurorae__svg__WhiteSur-dark
kwriteconfig6 --file kwinrc --group org.kde.kdecoration2 --key ButtonsOnLeft XAI
kwriteconfig6 --file kwinrc --group org.kde.kdecoration2 --key ButtonsOnRight ""
kwriteconfig6 --file kwinrc --group Plugins --key blurEnabled true
kwriteconfig6 --file Kvantum/kvantum.kvconfig --group General --key theme WhiteSur-dark

# Panel + dock layout (Niri-style bar + floating dock)
SCRIPT=$(tr '\n' ' ' < "$HOME/.local/bin/plasma-macos-panel.js")
qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$SCRIPT" 2>/dev/null || true

qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.refreshCurrentShell 2>/dev/null || true

# Ensure AppGrid plugin path is visible to plasmashell
export QT_PLUGIN_PATH="$HOME/.local/lib/qt6/plugins${QT_PLUGIN_PATH:+:$QT_PLUGIN_PATH}"
export QML2_IMPORT_PATH="$HOME/.local/lib/qml${QML2_IMPORT_PATH:+:$QML2_IMPORT_PATH}"

echo "macOS Plasma theme applied (Niri bar + WaveTask dock + AppGrid launcher)."
echo "Shortcut: Meta+Space (same as Niri Mod+Space on most keyboards)."
echo "Logout/login once if AppGrid icon doesn't appear on first run."