#!/usr/bin/env bash
set -euo pipefail

SESSION="${1:-}"
ACTION="${2:-}"

usage() {
    cat <<'EOF'
Usage: switch-desktop <niri|plasma> [now]

  switch-niri          Set Niri as default session (next login)
  switch-niri now      Switch to Niri and logout now
  switch-plasma        Set Plasma as default session (next login)
  switch-plasma now    Switch to Plasma and logout now
EOF
}

if [[ -z "$SESSION" ]]; then
    usage
    exit 1
fi

case "$SESSION" in
    niri)   DESKTOP="niri.desktop" ;;
    plasma) DESKTOP="plasma.desktop" ;;
    -h|--help|help)
        usage
        exit 0
        ;;
    *)
        echo "Unknown session: $SESSION"
        echo "Available: niri, plasma"
        exit 1
        ;;
esac

if [[ ! -f "/usr/share/wayland-sessions/$DESKTOP" ]]; then
    echo "Session not installed: $DESKTOP"
    exit 1
fi

AUTLOGIN_CONF="/etc/sddm.conf.d/10-autologin.conf"
if [[ -f "$AUTLOGIN_CONF" ]] && grep -q '^Session=' "$AUTLOGIN_CONF"; then
    sudo sed -i "s/^Session=.*/Session=$DESKTOP/" "$AUTLOGIN_CONF"
fi

mkdir -p "$HOME/.config/sddm"
printf '%s\n' "$DESKTOP" > "$HOME/.config/sddm/.desktop"

LABEL="$(tr '[:lower:]' '[:upper:]' <<< "${SESSION:0:1}")${SESSION:1}"
echo "Default session set to $LABEL ($DESKTOP)"

if [[ "$ACTION" == "now" ]]; then
    echo "Logging out in 3 seconds... (Ctrl+C to cancel)"
    sleep 3
    loginctl terminate-user "$USER"
else
    echo "Run 'switch-$SESSION now' to logout and apply immediately."
fi